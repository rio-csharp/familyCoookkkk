<view class="container">
  <view wx:if="{{loading}}" class="card state-card">加载中...</view>
  <view wx:if="{{!loading && errorText}}" class="card state-card">
    <view class="error-text">{{errorText}}</view>
    <button size="mini" class="btn-light" bindtap="reload">重试</button>
  </view>
  <view wx:if="{{!loading && !errorText && recipe}}">
  <!-- 封面图 -->
  <view class="cover-section" wx:if="{{recipe.coverUrl}}">
    <image class="cover-image" src="{{recipe.coverUrl}}" mode="aspectFill"></image>
    <view class="cover-overlay">
      <view class="cover-title">{{recipe.title}}</view>
      <view class="cover-author">👨‍🍳 {{recipe.authorName}}</view>
    </view>
  </view>
  
  <view class="card detail-card">
    <view class="section-title" wx:if="{{!recipe.coverUrl}}">{{recipe.title}}</view>
    <view class="subtle">{{recipe.description}}</view>
    <view class="tags-row"><text class="tag" wx:for="{{recipe.tags}}" wx:key="*this">{{item}}</text></view>
    <view class="meta-row">
      <view class="meta-item">
        <text class="meta-icon">❤️</text>
        <text class="meta-text">{{recipe.likeCount}}</text>
      </view>
      <view class="meta-item">
        <text class="meta-icon">⭐</text>
        <text class="meta-text">{{recipe.favoriteCount}}</text>
      </view>
      <view class="meta-item">
        <text class="meta-icon">💬</text>
        <text class="meta-text">{{recipe.comments.length}}</text>
      </view>
    </view>
    <view class="btn-row action-row">
      <button size="mini" class="btn-action {{recipe.liked ? 'active' : ''}}" bindtap="like">
        <text>{{recipe.liked ? "❤️ 已赞" : "🤍 点赞"}}</text>
      </button>
      <button size="mini" class="btn-action {{recipe.favorited ? 'active' : ''}}" bindtap="favorite">
        <text>{{recipe.favorited ? "⭐ 已藏" : "🔖 收藏"}}</text>
      </button>
      <button size="mini" class="btn-action" bindtap="shareRecipe">
        <text>📤 分享</text>
      </button>
      <button wx:if="{{recipe.isOwner}}" size="mini" class="btn-action" bindtap="editRecipe">
        <text>✏️ 编辑</text>
      </button>
    </view>
    <button wx:if="{{recipe.isOwner}}" class="btn-delete" bindtap="deleteRecipe">删除食谱</button>
  </view>
  <view class="card">
    <view class="section-title">食材</view>
    <view wx:for="{{recipe.ingredients}}" wx:key="name">- {{item.name}}：{{item.amount}}</view>
  </view>
  <view class="card">
    <view class="section-title">步骤</view>
    <view wx:for="{{recipe.steps}}" wx:key="*this">{{index + 1}}. {{item}}</view>
  </view>
  <view class="card">
    <view class="section-title">评论互动</view>
    <view wx:for="{{recipe.comments}}" wx:key="id" class="comment-item">{{item.userName}}：{{item.content}}</view>
    <input class="input" value="{{comment}}" bindinput="onInput" placeholder="输入评论" />
    <button class="btn-primary" bindtap="submitComment" disabled="{{submitting}}">发布评论</button>
  </view>
  </view>
  <view wx:if="{{!loading && !errorText && !recipe}}" class="card state-card">未找到该食谱</view>
</view>
