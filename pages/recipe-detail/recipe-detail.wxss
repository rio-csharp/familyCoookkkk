/* 食谱详情页 */

/* 封面图区域 */
.cover-section {
  position: relative;
  width: 100%;
  height: 500rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.4) 50%, transparent 100%);
}

.cover-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.cover-author {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 详情卡片 */
.detail-card {
  margin-top: -10rpx;
  border-radius: 24rpx 24rpx 0 0;
}

.tags-row {
  margin: 16rpx 0;
}

.meta-row {
  display: flex;
  gap: 32rpx;
  margin: 20rpx 0;
  padding: 20rpx 0;
  border-top: 1rpx solid #FFE8D6;
  border-bottom: 1rpx solid #FFE8D6;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  font-size: 28rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
}

.action-row {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.btn-action {
  flex: 1;
  min-width: 140rpx;
  padding: 20rpx 16rpx;
  background: #FFF8F3;
  color: #333;
  border: 2rpx solid #FFE8D6;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.btn-action.active {
  background: linear-gradient(135deg, #F59E0B 0%, #F97316 100%);
  color: #fff;
  border-color: #F59E0B;
}

.btn-action:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.btn-delete {
  width: 100%;
  margin-top: 20rpx;
  padding: 24rpx;
  background: #FFF1F0;
  color: #EF4444;
  border: 1rpx solid #FCA5A5;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.comment-item {
  padding: 10rpx 0;
  border-bottom: 1rpx solid #ffe7d1;
}

.step-item {
  margin-bottom: 16rpx;
  position: relative;
}

.step-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 8rpx;
  height: 8rpx;
  background: var(--color-orange-400);
  border-radius: 50%;
}

.step-text {
  padding-left: 16rpx;
}


