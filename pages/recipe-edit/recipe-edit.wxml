<view class="container">
  <view class="card edit-card">
    <view class="page-header">
      <view class="header-icon">📝</view>
      <view class="header-title">{{id ? "编辑食谱" : "新建食谱"}}</view>
      <view class="header-desc">{{id ? "修改你的美食作品" : "分享你的美食秘方"}}</view>
    </view>

    <view class="form-section">
      <!-- 封面图上传 -->
      <view class="form-item">
        <view class="form-label">封面图片</view>
        <view class="cover-upload-area" bindtap="chooseCoverImage">
          <image wx:if="{{coverUrl}}" class="cover-preview" src="{{coverUrl}}" mode="aspectFill"></image>
          <view wx:else class="upload-placeholder">
            <text class="upload-icon">📷</text>
            <text class="upload-text">点击上传封面图</text>
            <text class="upload-hint">建议尺寸 750x500</text>
          </view>
          <view wx:if="{{coverUrl}}" class="remove-cover" catchtap="removeCoverImage">
            <text>✕</text>
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label required">食谱名称</view>
        <input class="input" data-f="title" value="{{title}}" bindinput="onInput" placeholder="给你的美食起个好听的名字" />
      </view>

      <view class="form-item">
        <view class="form-label">简介描述</view>
        <textarea class="textarea small" data-f="description" value="{{description}}" bindinput="onInput" placeholder="简单介绍一下这道菜的特色..." maxlength="200"></textarea>
      </view>

      <view class="form-item">
        <view class="form-label">标签</view>
        <input class="input" data-f="tags" value="{{tags}}" bindinput="onInput" placeholder="用逗号分隔，如：家常菜,下饭" />
        <view class="form-tip">例如：家常菜、下饭、快手菜</view>
      </view>

      <view class="form-item">
        <view class="form-label required">发布范围</view>
        <view class="visibility-options">
          <view class="visibility-option {{visibility === 'family' ? 'active' : ''}}" bindtap="onSelectFamily">
            <view class="visibility-icon">👨‍👩‍👧‍👦</view>
            <view class="visibility-info">
              <view class="visibility-name">仅家庭可见</view>
              <view class="visibility-desc">只有家庭成员能看到</view>
            </view>
            <view class="visibility-check" wx:if="{{visibility === 'family'}}">✓</view>
          </view>
          <view class="visibility-option {{visibility === 'community' ? 'active' : ''}}" bindtap="onSelectCommunity">
            <view class="visibility-icon">🌍</view>
            <view class="visibility-info">
              <view class="visibility-name">公开到社区</view>
              <view class="visibility-desc">所有用户都能看到</view>
            </view>
            <view class="visibility-check" wx:if="{{visibility === 'community'}}">✓</view>
          </view>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label required">食材清单</view>
        <view class="input-tip">每行格式：名称|用量</view>
        <textarea class="textarea" data-f="ingredients" value="{{ingredients}}" bindinput="onInput" placeholder="例如：鸡蛋|2个"></textarea>
      </view>

      <view class="form-item">
        <view class="form-label required">制作步骤</view>
        <view class="input-tip">每行一个步骤</view>
        <textarea class="textarea" data-f="steps" value="{{steps}}" bindinput="onInput" placeholder="例如：将鸡蛋打散"></textarea>
      </view>
    </view>

    <view class="save-section">
      <button class="btn-light mb-3" bindtap="aiOptimizeRecipe" disabled="{{aiOptimizing || saving}}">
        <text wx:if="{{!aiOptimizing}}">✨AI优化食谱</text>
        <text wx:if="{{aiOptimizing}}">AI优化中...</text>
      </button>
      <button class="btn-primary" bindtap="save" disabled="{{saving}}">
        <text class="flex align-center justify-center" wx:if="{{!saving}}">保存食谱</text>
        <text wx:if="{{saving}}">保存中...</text>
      </button>
    </view>
  </view>
</view>
