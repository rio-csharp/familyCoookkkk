<view class="container">
  <view wx:if="{{loading}}" class="card state-card">加载中...</view>
  <view wx:if="{{!loading && errorText}}" class="card state-card">
    <view class="error-text">{{errorText}}</view>
    <button size="mini" class="btn-light" bindtap="reload">重试</button>
  </view>
  <view wx:if="{{!loading && !errorText}}">
    <!-- 用户头部卡片 -->
    <view class="profile-header">
      <view class="header-bg"></view>
      <view class="header-content">
        <image wx:if="{{session.user.avatar}}" class="user-avatar" src="{{session.user.avatar}}" mode="aspectFill"></image>
        <open-data wx:else class="user-avatar" type="userAvatarUrl"></open-data>
        <view class="user-info">
          <text wx:if="{{session.user.name}}" class="user-name">{{session.user.name}}</text>
          <open-data wx:else class="user-nick" type="userNickName"></open-data>
          <view class="user-role">{{familyData && familyData.isSuperAdmin ? "超级管理员" : (familyData && familyData.myRole ? familyData.myRole : "成员")}}</view>
        </view>
        <view class="edit-btn" bindtap="showEditProfile">
          <text>编辑资料</text>
        </view>
      </view>
      <!-- 统计数据 -->
      <view class="stats-row">
        <view class="stat-item">
          <view class="stat-num">{{stats.recipeCount || 0}}</view>
          <view class="stat-label">我的菜谱</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-num">{{stats.familyCount || memberships.length}}</view>
          <view class="stat-label">加入家庭</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-num">{{stats.memberCount || (familyData.family && familyData.family.members ? familyData.family.members.length : 0)}}</view>
          <view class="stat-label">家庭成员</view>
        </view>
      </view>
    </view>

    <!-- 当前家庭信息 -->
    <view class="card current-family-card">
      <view class="card-header">
        <text class="section-title">当前家庭</text>
        <text class="family-name">{{familyData && familyData.family ? familyData.family.name : "未加入家庭"}}</text>
      </view>
      <view class="family-members" wx:if="{{familyData && familyData.family && familyData.family.members}}">
        <view class="member-avatar" wx:for="{{familyData.family.members}}" wx:key="id">
          <image wx:if="{{item.avatar}}" src="{{item.avatar}}" mode="aspectFill"></image>
          <open-data wx:else type="userAvatarUrl" openid="{{item.openid}}"></open-data>
        </view>
        <view class="member-count">{{familyData.family.members.length}}人</view>
      </view>
      <button class="btn-light btn-block" bindtap="goFamily">家庭管理</button>
    </view>

    <!-- 功能菜单 -->
    <view class="card menu-card">
      <view class="section-title">功能</view>
      <view class="menu-list">
        <view class="menu-item" bindtap="goMyRecipes">
          <view class="menu-text">我的菜谱</view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="showFamilyList">
          <view class="menu-text">切换家庭</view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" wx:if="{{familyData.isSuperAdmin}}" bindtap="showAllFamilies">
          <view class="menu-text">全部家庭</view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="showSettings">
          <view class="menu-text">设置</view>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="showHelp">
          <view class="menu-text">帮助与反馈</view>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="card logout-card">
      <button class="btn-light btn-block logout-btn" bindtap="logout" disabled="{{busy}}">退出登录</button>
    </view>

    <!-- 编辑资料弹窗 -->
    <view class="modal-mask" wx:if="{{showEditModal}}" bindtap="hideEditProfile">
      <view class="modal-content" catchtap="stopPropagation">
        <view class="modal-header">
          <text>编辑资料</text>
          <text class="modal-close" bindtap="hideEditProfile">✕</text>
        </view>
        <view class="modal-body">
          <view class="form-group">
            <text class="form-label">头像</text>
            <view class="avatar-upload">
              <image wx:if="{{editAvatar}}" class="avatar-preview" src="{{editAvatar}}" mode="aspectFill"></image>
              <view wx:else class="avatar-placeholder">
                <text>上传头像</text>
              </view>
              <button class="btn-light btn-upload" bindtap="chooseAvatar" disabled="{{busy}}">
                {{editAvatar ? '更换' : '选择'}}
              </button>
            </view>
          </view>
          <view class="form-group">
            <text class="form-label">昵称</text>
            <input class="input" value="{{editNickname}}" bindinput="onInput" data-f="editNickname" placeholder="请输入昵称" />
          </view>
          <view class="form-group">
            <text class="form-label">手机号</text>
            <input class="input" value="{{editPhone}}" bindinput="onInput" data-f="editPhone" placeholder="请输入手机号" type="number" maxlength="11" />
          </view>
        </view>
        <view class="modal-footer">
          <button class="btn-light" bindtap="hideEditProfile">取消</button>
          <button class="btn-primary" bindtap="saveProfile" disabled="{{busy}}">保存</button>
        </view>
      </view>
    </view>

    <!-- 家庭切换弹窗 -->
    <view class="modal-mask" wx:if="{{showFamilyModal}}" bindtap="hideFamilyList">
      <view class="modal-content modal-small" catchtap="stopPropagation">
        <view class="modal-header">
          <text>切换家庭</text>
          <text class="modal-close" bindtap="hideFamilyList">✕</text>
        </view>
        <view class="modal-body">
          <view wx:if="{{!memberships.length}}" class="subtle text-center">当前未加入任何家庭</view>
          <view class="family-switch-item" wx:for="{{memberships}}" wx:key="familyId" bindtap="switchFamily" data-family-id="{{item.familyId}}">
            <view class="family-info">
              <text class="family-switch-name">{{item.familyName}}</text>
              <text class="family-switch-role">{{item.familyRole}}</text>
            </view>
            <view class="family-switch-status" wx:if="{{activeFamilyId === item.familyId}}">
              <text class="tag-active">当前</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 全部家庭弹窗 -->
    <view class="modal-mask" wx:if="{{showAllFamilyModal}}" bindtap="hideAllFamilies">
      <view class="modal-content modal-small" catchtap="stopPropagation">
        <view class="modal-header">
          <text>全部家庭</text>
          <text class="modal-close" bindtap="hideAllFamilies">✕</text>
        </view>
        <view class="modal-body">
          <view class="all-family-item" wx:for="{{familyData.families}}" wx:key="id">
            <view class="all-family-name">{{item.name}}</view>
            <view class="all-family-meta">成员 {{item.members.length}}</view>
            <view class="all-family-members">
              <text class="subtle" wx:for="{{item.members}}" wx:key="id">{{item.name}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
