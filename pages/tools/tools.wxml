<view class="container">
  <view wx:if="{{loading}}" class="card state-card">
    <view class="flex justify-center items-center py-8">
      <text class="text-brown-100">加载中...</text>
    </view>
  </view>
  <view wx:if="{{!loading && errorText}}" class="card state-card">
    <view class="error-text text-center">{{errorText}}</view>
    <view class="flex justify-center mt-4">
      <button size="mini" class="btn-light" bindtap="reload">重试</button>
    </view>
  </view>
  <view wx:if="{{!loading && !errorText}}">
    <!-- 采购清单 -->
    <view class="card tool-card">
      <view class="tool-header">
        <view class="tool-icon">🛒</view>
        <view class="tool-title">采购清单</view>
        <view class="tool-count">{{shoppingList.length}}项</view>
      </view>
      <view wx:if="{{shoppingList.length > 0}}" class="shopping-list">
        <view wx:for="{{shoppingList}}" wx:key="index" class="shopping-item">
          <text class="item-index">{{index + 1}}</text>
          <text class="item-text">{{item}}</text>
          <button size="mini" class="btn-light delete-btn" data-i="{{index}}" bindtap="removeItem" disabled="{{busy}}">删除</button>
        </view>
      </view>
      <view wx:else class="empty-state">暂无清单项，快添加吧~</view>
      <view class="add-area">
        <input class="input" data-f="newItem" value="{{newItem}}" bindinput="onInput" placeholder="输入要购买的食材..." />
        <button class="btn-primary add-btn" bindtap="addItem" disabled="{{busy}}">添加</button>
      </view>
    </view>

    <!-- 烹饪计时器 -->
    <view class="card tool-card">
      <view class="tool-header">
        <view class="tool-icon">⏱️</view>
        <view class="tool-title">烹饪计时器</view>
      </view>
      <view class="timer-display">
        <text class="timer-time">{{timerText}}</text>
        <text class="timer-label">剩余时间</text>
      </view>
      <view class="timer-input-wrapper">
        <input class="input" data-f="timerValue" value="{{timerValue}}" bindinput="onInput" placeholder="时间" type="number" />
        <view class="timer-unit">
          <view class="unit-option {{timerUnit === 'min' ? 'active' : ''}}" bindtap="selectUnit" data-unit="min">分钟</view>
          <view class="unit-option {{timerUnit === 'hour' ? 'active' : ''}}" bindtap="selectUnit" data-unit="hour">小时</view>
        </view>
      </view>
      <view class="timer-buttons">
        <button size="default" class="btn-primary timer-btn" bindtap="startTimer">开始计时</button>
        <button size="default" class="btn-light timer-btn" bindtap="stopTimer">停止</button>
      </view>
    </view>

    <!-- 今日吃什么 -->
    <view class="card tool-card">
      <view class="tool-header">
        <view class="tool-icon">🍳</view>
        <view class="tool-title">今日吃什么</view>
      </view>
      <button class="btn-primary random-btn" bindtap="randomRecipe">随机推荐一道菜</button>
      <view class="random-result">{{randomText}}</view>
    </view>

    <!-- AI 冰箱推荐 -->
    <view class="card tool-card">
      <view class="tool-header">
        <view class="tool-icon">🤖</view>
        <view class="tool-title">冰箱推荐菜谱</view>
      </view>
      <button class="btn-primary random-btn" bindtap="toggleRecommendPanel">
        {{showRecommend ? '收起推荐面板' : '按食材智能推荐'}}
      </button>
      <view wx:if="{{showRecommend}}" class="mt-4">
        <textarea
          class="textarea"
          placeholder="输入食材，用逗号或空格分隔，例如：番茄 鸡蛋 洋葱"
          value="{{recommendIngredients}}"
          bindinput="onInput"
          data-f="recommendIngredients"
          maxlength="200"
        ></textarea>
        <button class="btn-primary mt-3" bindtap="aiRecommendRecipes" disabled="{{recommendLoading}}">
          {{recommendLoading ? '推荐中...' : '获取推荐'}}
        </button>
        <view wx:if="{{recommendList.length > 0}}" class="mt-4">
          <view wx:for="{{recommendList}}" wx:key="index" class="shopping-item">
            <text class="item-index">{{index + 1}}</text>
            <view class="flex-1">
              <view class="font-semibold text-brown-500">{{item.title}}</view>
              <view class="text-brown-100 text-sm mt-1">{{item.description}}</view>
              <view wx:if="{{item.additionalIngredients && item.additionalIngredients.length}}" class="text-brown-100 text-xs mt-1">
                还需：{{item.additionalIngredients.join('、')}}
              </view>
            </view>
          </view>
        </view>
        <view wx:if="{{!recommendLoading && recommendList.length === 0}}" class="empty-state mt-3">
          输入食材后点击“获取推荐”
        </view>
      </view>
    </view>

    <!-- 开发工具 -->
    <view class="card tool-card dev-card">
      <view class="tool-header">
        <view class="tool-icon">🔧</view>
        <view class="tool-title">开发工具</view>
      </view>
      <view class="dev-tools">
        <button class="btn-light dev-btn" bindtap="testCloudConnection" disabled="{{busy}}">
          <view class="dev-btn-icon">☁️🤖</view>
          <view class="dev-btn-text">测试云开发 + AI连接</view>
        </button>
        <button class="btn-light dev-btn" bindtap="addSampleRecipes" disabled="{{busy}}">
          <view class="dev-btn-icon">📚</view>
          <view class="dev-btn-text">初始化示例数据</view>
        </button>
      </view>
      <view wx:if="{{aiTestResult || cloudTestResult || recipeResult}}" class="diagnostic-wrapper">
        <text class="diagnostic-text">{{aiTestResult || cloudTestResult || recipeResult}}</text>
        <button class="copy-btn" size="mini" bindtap="copyDiagnosticText">
          📋 复制
        </button>
      </view>
    </view>
  </view>
</view>

