/* 工具页面 */
.tool-card {
  margin-bottom: 24rpx;
}

/* 工具卡片头部 */
.tool-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-orange-200);
}

.tool-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.tool-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-brown-300);
}

.tool-count {
  font-size: 24rpx;
  color: var(--color-brown-100);
  background: var(--color-orange-100);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

/* 采购清单 */
.shopping-list {
  max-height: 400rpx;
  overflow-y: auto;
  margin-bottom: 16rpx;
}

.shopping-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--color-orange-50);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  transition: all 0.2s;
}

.item-index {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-orange-300);
  color: #fff;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 12rpx;
}

.item-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-brown-50);
}

.delete-btn {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
}

.add-area {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.add-area .input {
  flex: 1;
  margin-bottom: 0;
}

.add-btn {
  width: 120rpx;
  flex-shrink: 0;
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.empty-state {
  text-align: center;
  color: var(--color-brown-100);
  font-size: 26rpx;
  padding: 40rpx 0;
  background: var(--color-orange-50);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

/* 计时器 */
.timer-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  background: linear-gradient(135deg, var(--color-orange-100), var(--color-orange-50));
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.timer-time {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--color-orange-400);
  line-height: 1;
  margin-bottom: 8rpx;
}

.timer-label {
  font-size: 24rpx;
  color: var(--color-brown-100);
}

.timer-input-wrapper {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.timer-input-wrapper .input {
  flex: 1;
  margin-bottom: 0;
}

.timer-unit {
  display: flex;
  background: var(--color-orange-100);
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.unit-option {
  padding: 0 20rpx;
  height: 74rpx;
  line-height: 74rpx;
  font-size: 26rpx;
  color: var(--color-brown-100);
  transition: all 0.3s;
}

.unit-option.active {
  background: var(--color-orange-400);
  color: #fff;
}

.timer-buttons {
  display: flex;
  gap: 16rpx;
}

.timer-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
}

/* 今日吃什么 */
.random-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(232, 118, 38, 0.3);
}

.random-result {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-orange-500);
  padding: 20rpx;
  background: var(--color-orange-50);
  border-radius: 16rpx;
}

/* 开发工具 */
.dev-card {
  border: 2rpx dashed var(--color-orange-300);
}

.dev-tools {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.dev-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  height: auto;
  line-height: 1.4;
}

.dev-btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.dev-btn-text {
  font-size: 24rpx;
}

.diagnostic-text {
  display: block;
  font-size: 22rpx;
  color: var(--color-brown-100);
  text-align: center;
  padding: 12rpx;
  background: var(--color-orange-50);
  border-radius: 8rpx;
}

/* 原有样式保留兼容 */
.timer-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #9a541f;
  margin-bottom: 8rpx;
}

.recommend-text {
  margin-top: 10rpx;
  color: #d4762f;
}







