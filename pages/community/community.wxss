/* 社区页面 */
.hero {
  background: linear-gradient(145deg, #fff7ef, #fff);
}

/* 热度轮播图区域 */
.hot-section {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.08);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.section-subtitle {
  font-size: 22rpx;
  color: #999;
}

.hot-swiper-container {
  position: relative;
}

.hot-swiper {
  width: 100%;
  height: 440rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.hot-item {
  width: 100%;
  height: 100%;
}

.hot-card {
  width: 100%;
  height: 100%;
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #FFE8D6 0%, #FFD4A8 100%);
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.2);
}

.hot-cover {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.hot-cover-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hot-cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #FFE8D6 0%, #FFD4A8 100%);
}

.hot-placeholder-text {
  font-size: 96rpx;
  font-weight: 700;
  color: #F59E0B;
  opacity: 0.3;
}

.hot-placeholder-emoji {
  font-size: 120rpx;
  opacity: 0.5;
}

.hot-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
}

.hot-badge-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.hot-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.4), transparent);
  padding: 80rpx 20rpx 20rpx;
  color: #fff;
}

.hot-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-desc {
  display: block;
  font-size: 22rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hot-meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
}

.hot-meta-icon {
  font-size: 22rpx;
}

.hot-meta-text {
  font-size: 20rpx;
  font-weight: 600;
}

/* 筛选区域 */
.filter-section {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.filter-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.filter-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
}

.filter-count {
  font-size: 22rpx;
  color: #999;
}

.filter-tags {
  width: 100%;
  white-space: nowrap;
}

.tag-list {
  display: inline-flex;
  gap: 12rpx;
}

.filter-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: #FFF8F3;
  color: #666;
  font-size: 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid #FFE8D6;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.filter-tag.active {
  background: linear-gradient(135deg, #F59E0B 0%, #F97316 100%);
  color: #fff;
  border-color: #F59E0B;
  transform: scale(1.05);
}

.filter-tag:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* 网格布局 */
.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

/* 食谱卡片 */
.recipe-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.08);
  transition: all 0.3s ease;
  border: 1rpx solid #ffe5cc;
}

.recipe-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.15);
}

/* 封面图 */
.card-cover {
  width: 100%;
  height: 280rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #FFE8D6 0%, #FFD4A8 100%);
}

.cover-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.placeholder-text {
  font-size: 64rpx;
  font-weight: 700;
  color: #F59E0B;
  opacity: 0.3;
}

.placeholder-emoji {
  font-size: 80rpx;
  opacity: 0.5;
}

/* 卡片内容 */
.card-body {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.card-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  min-height: 66rpx;
}

/* 标签 */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag-item {
  padding: 4rpx 12rpx;
  background: #FFF8F3;
  color: #F59E0B;
  font-size: 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid #FFE8D6;
}

/* 元数据 */
.card-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #F5F5F5;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: #999;
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  font-size: 20rpx;
}





