page {
  background: linear-gradient(180deg, #FFF8F3 0%, #FFFBF8 100%);
  min-height: 100vh;
}

.container {
  padding: 30rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #FFE4CC;
  border-top-color: #F59E0B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  color: #999;
  font-size: 28rpx;
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 30rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.error-text {
  color: #666;
  font-size: 28rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 30rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 按钮样式 */
.btn-orange {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #F97316 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.3);
  transition: all 0.2s ease;
}

.btn-orange::after {
  border: none;
}

.btn-orange:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-large {
  padding: 32rpx;
  font-size: 34rpx;
}

/* 菜谱列表 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.section-count {
  font-size: 26rpx;
  color: #999;
}

.recipe-list {
  padding-bottom: 20rpx;
}

.recipe-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.08);
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.recipe-item:active {
  transform: scale(0.98);
}

.recipe-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #FFE8D6 0%, #FFD4A8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  font-size: 48rpx;
  font-weight: 700;
  color: #F59E0B;
}

.recipe-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.recipe-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.recipe-meta {
  display: flex;
  gap: 16rpx;
}

.meta-item {
  font-size: 22rpx;
  color: #999;
}

.recipe-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 20rpx;
}

.btn-edit,
.btn-delete {
  padding: 16rpx 24rpx;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.btn-edit::after,
.btn-delete::after {
  border: none;
}

.btn-edit {
  background: #F59E0B;
  color: #fff;
}

.btn-delete {
  background: #F5F5F5;
  color: #EF4444;
}

.btn-edit:active,
.btn-delete:active {
  transform: scale(0.94);
  opacity: 0.8;
}

/* 悬浮按钮 */
.fab-container {
  position: fixed;
  bottom: 120rpx;
  right: 30rpx;
  z-index: 999;
}

.fab-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 160rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #F97316 100%);
  border: none;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.4);
  transition: all 0.3s ease;
}

.fab-btn::after {
  border: none;
}

.fab-btn:active {
  transform: scale(0.94);
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
}

.fab-icon {
  font-size: 40rpx;
  font-weight: 300;
  color: #fff;
}

.fab-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}
