page {
  background: linear-gradient(180deg, #FFF8F3 0%, #FFFBF8 100%);
  min-height: 100vh;
}

.container {
  padding: 30rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #FFE4CC;
  border-top-color: #F59E0B;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  color: #999;
  font-size: 28rpx;
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 30rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.error-text {
  color: #666;
  font-size: 28rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 30rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

/* 按钮样式 */
.btn-orange {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #F97316 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.3);
  transition: all 0.2s ease;
}

.btn-orange::after {
  border: none;
}

.btn-orange:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.btn-large {
  padding: 32rpx;
  font-size: 34rpx;
}

/* 菜谱列表 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.section-count {
  font-size: 26rpx;
  color: #999;
}

.recipe-list {
  padding-bottom: 20rpx;
}

/* 网格布局 */
.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

/* 卡片容器 */
.recipe-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.08);
  transition: all 0.3s ease;
}

.recipe-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.15);
}

/* 封面图 */
.card-cover {
  width: 100%;
  height: 280rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #FFE8D6 0%, #FFD4A8 100%);
}

.cover-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.placeholder-text {
  font-size: 64rpx;
  font-weight: 700;
  color: #F59E0B;
  opacity: 0.3;
}

.placeholder-emoji {
  font-size: 80rpx;
  opacity: 0.5;
}

/* 卡片内容区 */
.card-body {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.card-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  min-height: 66rpx;
}

/* 元数据 */
.card-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #F5F5F5;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  color: #999;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 20rpx;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 8rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 16rpx 12rpx;
  border: none;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.action-btn::after {
  border: none;
}

.btn-icon {
  font-size: 24rpx;
}

.edit-btn {
  background: linear-gradient(135deg, #F59E0B 0%, #F97316 100%);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.25);
}

.delete-btn {
  background: #FFF1F0;
  color: #EF4444;
}

.edit-btn:active {
  opacity: 0.8;
  transform: scale(0.96);
}

.delete-btn:active {
  opacity: 0.8;
  transform: scale(0.96);
}

/* 悬浮按钮 */
.fab-container {
  position: fixed;
  bottom: 120rpx;
  right: 30rpx;
  z-index: 999;
}

.fab-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 160rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #F97316 100%);
  border: none;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.4);
  transition: all 0.3s ease;
}

.fab-btn::after {
  border: none;
}

.fab-btn:active {
  transform: scale(0.94);
  box-shadow: 0 4rpx 12rpx rgba(245, 158, 11, 0.3);
}

.fab-icon {
  font-size: 40rpx;
  font-weight: 300;
  color: #fff;
}

.fab-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}
