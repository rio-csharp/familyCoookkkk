<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{errorText}}" class="error-container">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{errorText}}</text>
    <button class="btn-orange" bindtap="loadRecipes">重试</button>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!recipes.length}}" class="empty-container">
    <text class="empty-icon">📖</text>
    <text class="empty-text">还没有发布菜谱</text>
    <text class="empty-hint">去创建你的第一个菜谱吧！</text>
    <button class="btn-orange btn-large" bindtap="goCreateRecipe">创建菜谱</button>
  </view>

  <!-- 菜谱列表 -->
  <view wx:else class="recipe-list">
    <view class="section-header">
      <text class="section-title">我的菜谱</text>
      <text class="section-count">共 {{recipes.length}} 篇</text>
    </view>

    <view class="recipe-grid">
      <view class="recipe-card" wx:for="{{recipes}}" wx:key="id" bindtap="viewRecipe" data-id="{{item.id}}">
        <!-- 封面图 -->
        <view class="card-cover">
          <image wx:if="{{item.coverUrl}}" class="cover-image" src="{{item.coverUrl}}" mode="aspectFill"></image>
          <view wx:else class="cover-placeholder">
            <text class="placeholder-text">{{item.title.charAt(0)}}</text>
            <text class="placeholder-emoji">🍳</text>
          </view>
        </view>

        <!-- 菜谱信息 -->
        <view class="card-body">
          <text class="card-title">{{item.title}}</text>
          <text class="card-desc">{{item.description || '暂无描述'}}</text>
          
          <view class="card-meta">
            <view class="meta-item">
              <text class="meta-icon">🕐</text>
              <text class="meta-text">{{item.createTime}}</text>
            </view>
            <view class="meta-item">
              <text class="meta-icon">👁️</text>
              <text class="meta-text">{{item.viewCount || 0}}</text>
            </view>
          </view>

          <!-- 操作按钮 -->
          <view class="card-actions">
            <button class="action-btn edit-btn" catchtap="editRecipe" data-id="{{item.id}}" hover-class="none">
              <text class="btn-icon">✏️</text>
              <text>编辑</text>
            </button>
            <button class="action-btn delete-btn" catchtap="deleteRecipe" data-id="{{item.id}}" hover-class="none">
              <text class="btn-icon">🗑️</text>
              <text>删除</text>
            </button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部创建按钮 -->
  <view wx:if="{{recipes.length > 0}}" class="fab-container">
    <button class="fab-btn" bindtap="goCreateRecipe">
      <text class="fab-icon">+</text>
      <text class="fab-text">创建菜谱</text>
    </button>
  </view>
</view>
